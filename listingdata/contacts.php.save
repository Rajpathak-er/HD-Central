                //print_r($term);
                if($term->parent == 0 ){
                  $catname[] = $term->name;
                  }else{
                  $catchildname[] = $term->name;
                  }

                }
              }


              }
              $provider->Categories= $catname;
              $provider->Categorieschild= $catchildname;
              $newProvider->Categories= $catname;
              $newProvider->Categorieschild= $catchildname;


