function cmp($a, $b) {
    return strcmp($a->name, $b->name);
}

function cmpdesc($a, $b) {
    return strcmp($b->name, $a->name);
}


function get_terms_by_posttype($taxonomy, $postType) {

    // Get all terms that have posts
    $terms = get_terms($taxonomy, [
        'hide_empty' => true,
        'orderby' => 'name',
        'order' => 'ASC',
    ]);
    $filterterms = array();
foreach($terms as $term){
  //echo $term->term_id;
  if($taxonomy == "region" && $term->parent == 0){
   // continue;
  }


      $tax_query = array();
      $tax_query[] = array('taxonomy' => $taxonomy,
                'terms' => $term->term_id);

      if(!empty($_GET['year'])){
          $tax_query[] = array('taxonomy' => 'ca-year',
                'terms' => $_GET['year']);
      }

      if(!empty($_GET['Region'])){
          $tax_query[] = array('taxonomy' => 'region',
                'terms' => $_GET['Region']);
      }


      if(!empty($_GET['model'])){
          $tax_query[] = array('taxonomy' => 'make',
                'terms' => $_GET['model']);
      }


    // filter by condition
    if( !empty($_GET['condition']) ){
      $condition = $_GET['condition'];
      $tax_query[] = array(
        'taxonomy' => 'condition',
        'field' => 'term_id',
        'terms' => $condition,
      );
    }

    // filter by seller
    if( !empty($_GET['seller']) ){
      $seller = $_GET['seller'];
      $tax_query[] = array(
        'taxonomy' => 'seller',
        'field' => 'term_id',
        'terms' => $seller,
        );
    }


        $args = array('fields' => 'ids',
            'posts_per_page' => 1,
            'post_type' => $postType,
            'tax_query' => $tax_query,
        );



        // filter by keywords
    if( !empty($_GET['ca_keywords']) ){
      $args['s'] = $_GET['ca_keywords'];
    }


 //   if($term->term_id == '3446'){
 //      print_r($args);
        $posts = new WP_Query($args);


//          echo $posts->request;
//          die;
 //       }

        if((($posts->found_posts) > 0)){
      //    echo $posts->found_posts."<br/>";
            $term->count = $posts->found_posts;
            $filterterms[] = $term;
        }


}
/*
    // Remove terms that don't have any posts in the current post type
    $terms = array_filter($terms, function ($term) use ($postType, $taxonomy) {
      $tax_query = array();
      $tax_query[] = array('taxonomy' => $taxonomy,
                'terms' => $term);

      if(!empty($_GET['year'])){
          $tax_query[] = array('taxonomy' => 'ca-year',
                'terms' => $_GET['year']);
      }

      if(!empty($_GET['model'])){
          $tax_query[] = array('taxonomy' => 'make',
                'terms' => $_GET['model']);
      }


        $args = array('fields' => 'ids',
            'posts_per_page' => 1,
            'post_type' => $postType,
            'tax_query' => $tax_query,
        );
        $posts = new WP_Query($args);
       // echo $posts->found_posts;

        return (($posts->found_posts) > 0);
    });
  // echo "<pre>";
   //     print_r($terms);
    //    echo "</pre>";
     */
    // Return whatever we have left
    if($taxonomy == 'ca-year'){
      usort($filterterms, "cmpdesc");
    }else{
       usort($filterterms, "cmp");
    }
    // echo "<pre>";
    // print_r($filterterms);
    // echo "</pre>";
    return $filterterms;
}


add_filter('posts_clauses_request', 'stm_listings_posts_clauses_bike', 100, 2);

function stm_listings_posts_clauses_bike($clauses, WP_Query $query)
{

    global $wpdb;
    $table_prefix = $wpdb->prefix;

  //  echo "hook called";

    if (!empty($_GET['stm_lat'])) {


    $distance = 999999999;
    if(!empty($_GET['distance'])){
      $distance = $_GET['distance'];
    }

    $formula = '6378.137 * ACOS(COS(RADIANS(stm_lat_prefix.meta_value)) * COS(RADIANS(:lat)) * COS(RADIANS(stm_lng_prefix.meta_value) - RADIANS(:lng)) + SIN(RADIANS(stm_lat_prefix.meta_value)) * SIN(RADIANS(:lat)))';
    $formula = strtr($formula, array(
        ':lat' => floatval($_GET['stm_lat']),
        ':lng' => floatval($_GET['stm_lng']),
    ));

    $clauses['fields'] .= ", ($formula) AS stm_distance";


      $clauses['where'] .= " and ($formula) < ".$distance. "  ";


//print_r($clauses['where']);

    $clauses['join'] .= " INNER JOIN {$table_prefix}postmeta stm_lat_prefix ON ({$table_prefix}posts.ID = stm_lat_prefix.post_id AND stm_lat_prefix.meta_key = 'stm_lat_car_admin')";
    $clauses['join'] .= " INNER JOIN {$table_prefix}postmeta stm_lng_prefix ON ({$table_prefix}posts.ID = stm_lng_prefix.post_id AND stm_lng_prefix.meta_key = 'stm_lng_car_admin')";

    $clauses['orderby'] = 'stm_distance ASC, ' . $clauses['orderby'];

  }

  if(!empty($_GET['max_mileage']) && $_GET['max_mileage'] != '100000' && $_GET['min_mileage'] != '0'){
        $min_mileage = $_GET['min_mileage'];
        $max_mileage = $_GET['max_mileage'];
        $clauses['where'] .= " and  (stm_mileage.meta_value > ".$min_mileage. " and   stm_mileage.meta_value < ". $max_mileage ." )";
        $clauses['join'] .= " INNER JOIN {$table_prefix}postmeta stm_mileage ON ({$table_prefix}posts.ID = stm_mileage.post_id AND stm_mileage.meta_key = 'mileage') ";
    }
    if(!empty($_GET['max_price']) && $_GET['max_price'] != '100000' && $_GET['min_price'] != '0'){
        $min_price = $_GET['min_price'];
        $max_price = $_GET['max_price'];
        $clauses['where'] .= " and  (stm_price.meta_value > ".$min_price. " and   stm_price.meta_value < ". $max_price ." )";
        $clauses['join'] .= " INNER JOIN {$table_prefix}postmeta stm_price ON ({$table_prefix}posts.ID = stm_price.post_id AND stm_price.meta_key = 'price') ";
    }


//    if($query->get('orderby') == 'stm_distance'){

  //  }
  //  print_r($clauses);

    return apply_filters('stm_listings_clauses_filter', $clauses);
}


