              $newProvider->brandsname= $brandsnames;
              }else{
                $provider->brandsname= '';
                $newProvider->brandsname= '';
              }
              $ratings = stm_get_dealer_marks($provider->user_id);
              if (!empty($ratings['average'])){
                  $provider->star = $ratings['average'];
              }else{
                $newProvider->star = 0;
              }


