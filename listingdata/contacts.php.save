function get_taxonomy_hierarchy_listing( $taxonomy, $parent = 0 ) {
  //echo $taxonomy;
  // only 1 taxonomy
  $taxonomy = is_array( $taxonomy ) ? array_shift( $taxonomy ) : $taxonomy;
  // get all direct descendants of the $parent
  $terms = get_terms( $taxonomy, array( 'parent' => $parent ,'hide_empty' => true) );

  // prepare a new array.  these are the children of $parent
  // we'll ultimately copy all the $terms into this new array, but only after they
  // find their own children
  $children = array();
  // go through all the direct descendants of $parent, and gather their children
  foreach ( $terms as $term ){
    // recurse to get the direct descendants of "this" term
    //$term->children = get_taxonomy_hierarchy( $taxonomy, $term->term_id );

    $newchild= array();
    $termschild  = get_terms( $taxonomy, array( 'parent' => $term->term_id ,'hide_empty' => true) );
    foreach ( $termschild as $termchild ){
    // add the term to our new array
        $newchild[ $termchild->term_id ]['name'] = $termchild->name;
        $newchild[ $termchild->term_id ]['term_id'] = $termchild->term_id;
        $newchild[ $termchild->term_id ]['child'] = $termchild->children;
    }


    // add the term to our new array
    $children[ $term->term_id ]['name'] = $term->name;
    $children[ $term->term_id ]['term_id'] = $term->term_id;
    $term->children =  $newchild;
    $children[ $term->term_id ]['child'] = $term->children;
  }
  // send the results back to the caller
  return $children;
}


